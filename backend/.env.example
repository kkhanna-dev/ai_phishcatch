# PhishCatch's analysis is a fully local, rule-based engine (no LLM, no API
# key, no external calls, no per-email cost) — see backend/lib/heuristicEngine.ts.
# The extension analyzes locally too, so it doesn't even need to reach this
# API for autonomous Gmail monitoring. This backend/web app remains useful as
# a standalone tool for pasting in a suspicious email from any browser.

# Comma-separated list of origins allowed to call /api/* cross-origin, e.g. a
# separate web deployment of this app calling the API from a different
# domain. Same-origin requests from this app's own frontend never need this.
ALLOWED_ORIGINS=

# Requests allowed per IP per window on /api/analyze.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

