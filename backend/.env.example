ANTHROPIC_API_KEY=your_api_key_here

# Comma-separated list of origins allowed to call /api/* cross-origin, e.g. the
# Chrome extension's origin and any web deployment of this app that calls the API
# from a different domain. Same-origin requests from this app's own frontend
# never need this.
ALLOWED_ORIGINS=chrome-extension://REPLACE_WITH_YOUR_EXTENSION_ID

# Requests allowed per IP per window on /api/analyze.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

